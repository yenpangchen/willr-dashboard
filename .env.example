# Copy to `.env` and fill in locally. Do not commit `.env`.
# This project uses Yahoo Finance (yfinance) without an API key for quotes.

# Optional: comma-separated browser origins when UI and API are on different hosts
# WILLR_CORS_ORIGINS=https://your-frontend.example.com

# Optional: override path to built dashboard static files
# WILLR_STATIC_DIR=/path/to/dashboard/dist

# Optional: Vite build-time API base (different domain from static host)
# VITE_API_BASE=https://your-api.example.com
